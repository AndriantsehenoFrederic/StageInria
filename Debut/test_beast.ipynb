# Grafique pour chaque modèle à partir de resultats.csv
import pandas as pd
import matplotlib.pyplot as plt
import seaborn as sns

# Lecture des données
path_csv = "resultats.csv"  # chemin relatif depuis le notebook, ou chemin absolu
df = pd.read_csv(path_csv)

# Conversion de colonnes si necessaire
for c in ["Modèle", "Nombre de tokens", "Durée totale de réponse", "Temps pour recevoir le premier token"]:
    if c not in df.columns and c.lower() in df.columns:
        df = df.rename(columns={c.lower(): c})

# Gestion valeurs numériques
if df["Nombre de tokens"].dtype == object:
    try:
        # supprime les k, M si présents
        df["Nombre de tokens"] = df["Nombre de tokens"].astype(str).str.replace("k", "000", regex=False).astype(float)
    except Exception:
        pass

for col in ["Durée totale de réponse", "Temps pour recevoir le premier token"]:
    if df[col].dtype == object:
        df[col] = pd.to_numeric(df[col], errors='coerce')

# Tracé par modèle
sns.set(style="whitegrid")

# Figure globale: 1 plot par modèle
n = df["Modèle"].nunique()
cols = 2
rows = (n + cols - 1) // cols
fig, axes = plt.subplots(rows, cols, figsize=(12, 4 * rows), squeeze=False)

for (model, grp), ax in zip(df.groupby("Modèle"), axes.flatten()):
    grp = grp.sort_values("Nombre de tokens")
    ax.plot(grp["Nombre de tokens"], grp["Durée totale de réponse"], marker='o', label='Durée totale')
    ax.plot(grp["Nombre de tokens"], grp["Temps pour recevoir le premier token"], marker='s', label='Temps premier token')
    ax.set_title(model)
    ax.set_xlabel("Nombre de tokens")
    ax.set_ylabel("Temps (s)")
    ax.legend()
    ax.grid(True)

# cache axes inutilisés si n < rows*cols
for ax in axes.flatten()[n:]:
    ax.set_visible(False)

plt.tight_layout()
plt.show()
